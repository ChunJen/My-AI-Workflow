generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkflowType {
  TEXT_SUMMARIZATION
  PROFESSIONAL_REWRITE
  TASK_BREAKDOWN
  GITHUB_ISSUE_ANALYSIS
  MEETING_NOTES_EXTRACTION
}

enum WorkflowStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
}

enum ExecutionStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

enum TriggerType {
  MANUAL
  SCHEDULED
  WEBHOOK
  API
}

enum AIProvider {
  ANTHROPIC
  OPENAI
  GEMINI
}

model Workflow {
  id           String         @id @default(cuid())
  title        String
  type         WorkflowType
  input        String         @db.Text
  latestOutput String?        @db.Text
  status       WorkflowStatus @default(DRAFT)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  executions   WorkflowExecution[]
  schedule     WorkflowSchedule?

  @@index([status])
  @@index([createdAt])
}

model WorkflowSchedule {
  id             String    @id @default(cuid())
  workflowId     String    @unique
  cronExpression String
  timezone       String    @default("Asia/Taipei")
  isActive       Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model WorkflowExecution {
  id               String          @id @default(cuid())
  workflowId       String
  workflow         Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  input            String          @db.Text
  output           String?         @db.Text
  status           ExecutionStatus @default(PENDING)
  provider         AIProvider      @default(ANTHROPIC)
  triggerType      TriggerType     @default(MANUAL)
  model            String?
  errorMessage     String?
  durationMs       Int?
  inputSnapshot    String?         @db.Text
  inputTokens      Int?
  outputTokens     Int?
  totalTokens      Int?
  estimatedCostUsd Float?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime        @default(now())

  @@index([workflowId])
  @@index([status])
  @@index([createdAt])
}
