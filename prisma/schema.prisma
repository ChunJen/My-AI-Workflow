generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkflowStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
}

enum ExecutionStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

enum TriggerType {
  MANUAL
  SCHEDULED
  WEBHOOK
  API
}

enum AIProvider {
  ANTHROPIC
  OPENAI
  GEMINI
}

model WorkflowTypeConfig {
  id                 String   @id @default(cuid())
  slug               String   @unique
  label              String
  description        String
  systemPrompt       String   @db.Text
  userPromptTemplate String   @db.Text
  isEnabled          Boolean  @default(true)
  isBuiltIn          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Workflow {
  id           String         @id @default(cuid())
  title        String
  type         String
  input        String         @db.Text
  latestOutput String?        @db.Text
  status       WorkflowStatus @default(DRAFT)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  executions   WorkflowExecution[]
  schedule     WorkflowSchedule?
  steps        WorkflowStep[]

  @@index([status])
  @@index([createdAt])
}

model WorkflowStep {
  id              String   @id @default(cuid())
  workflowId      String
  order           Int
  name            String
  type            String
  provider        String?
  systemPrompt    String   @db.Text
  userPrompt      String   @db.Text
  inputMapping    String?
  outputKey       String?
  promptVersion   Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workflow        Workflow               @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  executions      WorkflowStepExecution[]
  promptVersions  PromptVersion[]

  @@unique([workflowId, order])
  @@index([workflowId])
}

model PromptVersion {
  id           String   @id @default(cuid())
  stepId       String
  version      Int
  systemPrompt String   @db.Text
  userPrompt   String   @db.Text
  createdAt    DateTime @default(now())

  step WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([stepId, version])
  @@index([stepId])
}

model WorkflowSchedule {
  id             String    @id @default(cuid())
  workflowId     String    @unique
  cronExpression String
  timezone       String    @default("Asia/Taipei")
  isActive       Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model WorkflowExecution {
  id               String          @id @default(cuid())
  workflowId       String
  workflow         Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  input            String          @db.Text
  output           String?         @db.Text
  status           ExecutionStatus @default(PENDING)
  provider         AIProvider      @default(ANTHROPIC)
  triggerType      TriggerType     @default(MANUAL)
  model            String?
  errorMessage     String?
  durationMs       Int?
  inputSnapshot    String?         @db.Text
  inputTokens      Int?
  outputTokens     Int?
  totalTokens      Int?
  estimatedCostUsd Float?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime        @default(now())
  stepExecutions   WorkflowStepExecution[]

  @@index([workflowId])
  @@index([status])
  @@index([createdAt])
}

model WorkflowStepExecution {
  id               String    @id @default(cuid())
  executionId      String
  stepId           String
  status           String
  provider         String?
  model            String?
  promptVersion    Int?
  input            String    @db.Text
  output           String?   @db.Text
  errorMessage     String?
  inputTokens      Int?
  outputTokens     Int?
  totalTokens      Int?
  estimatedCostUsd Float?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  step      WorkflowStep      @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([stepId])
}
